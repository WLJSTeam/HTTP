Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"Get", "[", "\"\<KirillBelov`HTTP`\>\"", "]"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"handler", " ", "=", " ", 
    RowBox[{"HTTPHandler", "[", "\n", "\t", 
     RowBox[{
      RowBox[{"\"\<DefaultDeserializer\>\"", " ", "->", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"ImportByteArray", "[", 
         RowBox[{"#BodyByteArray", ",", " ", "\"\<RawJSON\>\""}], "]"}], 
        "]"}]}], ",", " ", "\n", "\t", 
      RowBox[{"\"\<DefaultSerializer\>\"", " ", "->", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"ExportString", "[", 
         RowBox[{"#", ",", " ", "\"\<RawJSON\>\""}], "]"}], "]"}]}], ",", " ",
       "\n", "\t", 
      RowBox[{"\"\<DefaultMessageHandler\>\"", " ", "->", " ", 
       RowBox[{"Function", "[", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<Code\>\"", " ", "->", " ", "200"}], ",", " ", 
          RowBox[{"\"\<Body\>\"", " ", "->", " ", "\"\<Hello\>\""}]}], "|>"}],
         "]"}]}]}], "\n", "]"}]}], ";"}], " ", "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"request", " ", "=", " ", 
    RowBox[{"HTTPRequest", "[", 
     RowBox[{"\"\<https://example.com?x=1\>\"", ",", " ", 
      RowBox[{"<|", "\n", "\t", 
       RowBox[{
        RowBox[{"Method", " ", "->", " ", "\"\<POST\>\""}], ",", " ", "\n", 
        "\t", 
        RowBox[{
        "\"\<ContentType\>\"", " ", "->", " ", 
         "\"\<application/json; charset=utf-8\>\""}], ",", " ", "\n", "\t", 
        RowBox[{"\"\<Body\>\"", " ", "->", " ", 
         RowBox[{"ExportByteArray", "[", 
          RowBox[{
           RowBox[{"<|", "\n", "\t\t", 
            RowBox[{"\"\<x\>\"", " ", "->", " ", "1"}], "\n", "\t", "|>"}], 
           ",", " ", "\"\<RawJSON\>\""}], "]"}]}]}], "\n", "|>"}]}], "]"}]}], 
   ";"}], " ", "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"requestString", " ", "=", " ", "\n", 
    RowBox[{"StringReplace", "[", 
     RowBox[{
      RowBox[{"ExportString", "[", 
       RowBox[{"request", ",", " ", "\"\<HTTPRequest\>\""}], "]"}], ",", " ", 
      "\n", "\t", 
      RowBox[{"\"\<\\n\>\"", " ", "->", " ", "\"\<\\r\\n\>\""}]}], "\n", 
     "]"}]}], ";"}], " ", "\n"}], "\n", 
 RowBox[{"handler", "[", 
  RowBox[{"<|", "\n", "\t", 
   RowBox[{"\"\<DataByteArray\>\"", " ", "->", " ", 
    RowBox[{"StringToByteArray", "[", "requestString", "]"}]}], "\n", "|>"}], 
  "]"}]}], "Code",
